# PayPal Sandbox Credentials
# Get these from https://developer.paypal.com/dashboard/

# Your PayPal Sandbox Client ID
# Used by the PayPal SDK to initialize payment buttons and Server Actions
PAYPAL_SANDBOX_CLIENT_ID=your_sandbox_client_id_here

# Your PayPal Sandbox Client Secret
# Used by Server Actions to create and capture orders
# NEVER expose this to the browser or public repositories
PAYPAL_SANDBOX_CLIENT_SECRET=your_sandbox_client_secret_here
